#### 4.1.3 Session Boundary Types (New)

```go
// SessionScope determines how inbound messages are routed to sessions.
// This is a SECURITY decision enforced by the framework, not application config.
type SessionScope string

const (
    // SessionScopeMain: all messages share one session per partition.
    // Use for single-user personal assistant.
    SessionScopeMain SessionScope = "main"

    // SessionScopePerChannelPeer: isolated by channel + sender ID.
    // Default for most deployments.
    SessionScopePerChannelPeer SessionScope = "per-channel-peer"

    // SessionScopePerThread: isolated by conversation thread.
    // Use for group chats with per-thread context.
    SessionScopePerThread SessionScope = "per-thread"
)

// SessionBoundary is a security envelope for a session.
// The framework enforces that an agent context cannot access
// events outside its declared boundary.
type SessionBoundary struct {
    SessionID  string       `json:"session_id" yaml:"session_id"`
    Scope      SessionScope `json:"scope" yaml:"scope"`
    Partition  string       `json:"partition" yaml:"partition"`
    ActorID    string       `json:"actor_id,omitempty" yaml:"actor_id,omitempty"`
    ChannelID  string       `json:"channel_id,omitempty" yaml:"channel_id,omitempty"`
    PeerID     string       `json:"peer_id,omitempty" yaml:"peer_id,omitempty"`
    TrustClass TrustClass   `json:"trust_class" yaml:"trust_class"`
    CreatedAt  time.Time    `json:"created_at" yaml:"created_at"`
}

// SessionBoundaryKey returns the canonical routing key for a scope.
// Two messages with the same key are in the same session.
func SessionBoundaryKey(scope SessionScope, partition, channel, peer, thread string) string {
    switch scope {
    case SessionScopeMain:
        return partition
    case SessionScopePerChannelPeer:
        return partition + ":" + channel + ":" + peer
    case SessionScopePerThread:
        return partition + ":" + channel + ":" + peer + ":" + thread
    default:
        return partition + ":" + channel + ":" + peer
    }
}
```

